{
  "name": "@opencolin/openclaw-nebius",
  "version": "1.2.2",
  "type": "module",
  "description": "Nebius Token Factory provider plugin for OpenClaw — 44+ open-source models via a single endpoint",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "openclaw": "^2026.4.5",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "providers": [
      "nebius"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.5"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "SETUP.md",
    "SKILL.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opencolin/openclaw-nebius.git",
    "directory": "tokenfactory-plugin"
  }
}
