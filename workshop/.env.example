# =====================================================================
# OpenClaw workshop — environment variables
# Copy this file to `.env` (in the same dir) and fill in real values.
# `.env` is gitignored. NEVER commit real keys.
# =====================================================================

# --- Nebius Token Factory ---------------------------------------------
# Get one at https://tokenfactory.nebius.com → API keys.
# Format: v1.<long string>
NEBIUS_API_KEY=v1.replace-me

# Pick any model you have access to. Use the `tokenfactory/` prefix — that
# matches the ClawHub plugin (`clawhub:tokenfactory`) bundled in this image.
# The 6 models highlighted in the workshop are pre-listed in the gateway config:
#   Kimi-K2.6, DeepSeek-V4-Pro, Nemotron-3-Nano-Omni, GLM-5.1,
#   MiniMax-M2.5, Qwen3.5-397B-A17B-fast
OPENCLAW_MODEL=tokenfactory/moonshotai/Kimi-K2.6

# US tenants: use https://api.tokenfactory.us-central1.nebius.com/v1
TOKEN_FACTORY_URL=https://api.tokenfactory.nebius.com/v1

# --- Tavily web search ------------------------------------------------
# Get one at https://app.tavily.com → API Keys.
# Format: tvly-<random>
TAVILY_API_KEY=tvly-replace-me

# --- Slack bot (Socket Mode) ------------------------------------------
# See SLACK-APP-SETUP.md if you don't have an app yet.
# Bot User OAuth Token — starts with xoxb-
SLACK_BOT_TOKEN=xoxb-replace-me
# App-Level Token with `connections:write` scope — starts with xapp-
SLACK_APP_TOKEN=xapp-replace-me

# --- OpenClaw gateway -------------------------------------------------
# Token required to connect to the dashboard / TUI. Leave blank and the
# entrypoint will generate a random one (printed at startup).
OPENCLAW_GATEWAY_TOKEN=
